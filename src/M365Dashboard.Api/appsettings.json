{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Security": {
    "RequireHttps": true,
    "ContentSecurityPolicy": "default-src 'self'; script-src 'self' https://atlas.microsoft.com; style-src 'self' 'unsafe-inline' https://atlas.microsoft.com; img-src 'self' data: https:; connect-src 'self' https://login.microsoftonline.com https://graph.microsoft.com https://api.github.com https://atlas.microsoft.com;"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "Audience": "",
    "CallbackPath": "/signin-oidc"
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Cache": {
    "DefaultTtlMinutes": 15,
    "SignInDataTtlMinutes": 5,
    "LicenseDataTtlMinutes": 60,
    "ReportDataTtlMinutes": 30
  },
  "KeyVault": {
    "Uri": "" 
  },
  "AzureMaps": {
    "SubscriptionKey": ""
  },
  "ContainerApp": {
    "SubscriptionId": "",
    "ResourceGroup": "",
    "Name": "",
    "GhcrRepo": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}